# Copy to .env.prod and fill in values — never commit .env.prod

# Database (Spring Boot)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/campalert
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Database (Atlas migrations — must match above credentials)
DB_USERNAME=
DB_PASSWORD=

# Redis — password is used by both Spring and the Redis container itself (--requirepass)
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# Recreation.gov
RECREATION_BASEURL=https://www.recreation.gov/api/

# RIDB (Recreation Information Database) — https://ridb.recreation.gov/landing
RIDB_BASEURL=https://ridb.recreation.gov/api/v1/
RIDB_APIKEY=

# Twilio — Twilio Console → Account Info
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio Messaging Service — Console → Messaging → Services → your service → Service SID
TWILIO_MESSAGING_SERVICE_SID=

# Twilio Verify — Console → Verify → Services → your service → Service SID
TWILIO_VERIFY_SERVICE_SID=

# Pushover (admin override only — set per-user in DB, not used by default)
PUSHOVER_API_TOKEN=
PUSHOVER_USER_TOKEN=

# Remember-me — cryptographic key for signing persistent remember-me tokens (maps to campfinder.security.remember-me-key)
# Generate with: openssl rand -hex 32
CAMPFINDER_SECURITY_REMEMBER_ME_KEY=
