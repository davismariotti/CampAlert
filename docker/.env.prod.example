# Copy to .env.prod and fill in values — never commit .env.prod

# Database (Spring Boot)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/campalert
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Database (Atlas migrations — must match above credentials)
DB_USERNAME=
DB_PASSWORD=

# Redis — password is used by both Spring and the Redis container itself (--requirepass)
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# RIDB (Recreation Information Database) — https://ridb.recreation.gov/landing
RIDB_APIKEY=

# Twilio — Twilio Console → Account Info
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio Messaging Service — Console → Messaging → Services → your service → Service SID
TWILIO_MESSAGING_SERVICE_SID=

# Twilio Verify — Console → Verify → Services → your service → Service SID
TWILIO_VERIFY_SERVICE_SID=

# Pushover (admin override only — set per-user in DB, not used by default)
PUSHOVER_API_TOKEN=
PUSHOVER_USER_TOKEN=

# Remember-me — cryptographic key for signing persistent remember-me tokens (maps to campfinder.security.remember-me-key)
# REQUIRED — startup will fail with IllegalStateException if unset or left as the default "change-me-in-production"
# Generate with: openssl rand -hex 32
CAMPFINDER_SECURITY_REMEMBER_ME_KEY=

# Postmark — Postmark dashboard → Servers → [server] → API Tokens → Server API Token
CAMPFINDER_EMAIL_POSTMARK_SERVER_TOKEN=

# Email — application-level settings (maps to campfinder.email.*)
CAMPFINDER_EMAIL_FROM_ADDRESS=

# New Relic APM — https://one.newrelic.com → API Keys → INGEST - LICENSE key
NEW_RELIC_LICENSE_KEY=
# Application name as it appears in the New Relic UI
NEW_RELIC_APP_NAME=CampAlert

# Notifications library (com.davismariotti:notifications-*) — activated in the dispatch step.
# Secrets are passed into the library from CampAlert; the library never reads env directly.
# SMS via Twilio (same credentials as the TWILIO_* vars above):
# NOTIFICATIONS_SMS_PROVIDER=twilio
# NOTIFICATIONS_SMS_TWILIO_ACCOUNT_SID=            # = TWILIO_ACCOUNT_SID
# NOTIFICATIONS_SMS_TWILIO_AUTH_TOKEN=             # = TWILIO_AUTH_TOKEN
# NOTIFICATIONS_SMS_TWILIO_MESSAGING_SERVICE_SID=  # = TWILIO_MESSAGING_SERVICE_SID
# Email via Postmark:
# NOTIFICATIONS_EMAIL_PROVIDER=postmark
# NOTIFICATIONS_EMAIL_FROM_ADDRESS=                # = CAMPFINDER_EMAIL_FROM_ADDRESS
# NOTIFICATIONS_EMAIL_POSTMARK_SERVER_TOKEN=       # = CAMPFINDER_EMAIL_POSTMARK_SERVER_TOKEN
# Push via Pushover (per-user admin override; credentials come from the DB, not env):
# NOTIFICATIONS_PUSH_PROVIDER=pushover
